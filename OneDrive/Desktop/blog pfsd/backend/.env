# ─── LILNEST Backend Environment ─────────────────────────────
DJANGO_SECRET_KEY=lilnest-change-this-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=*

# ─── MongoDB ─────────────────────────────────────────────────
MONGODB_NAME=lilnest_db
MONGODB_HOST=mongodb://localhost:27017

# ─── Redis & Celery ─────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Razorpay (leave empty for dev mode) ────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
